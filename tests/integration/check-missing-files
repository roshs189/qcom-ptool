# Takes rawprogram*.xml and contents.xml files as arguments, collects the
# filenames referenced, and checks if any gpt_* or zeros_* file is missing

set -eu

errors=no

for xml in "$@"; do
    dir="$(dirname "${xml}")"
    rawprogram_filenames="$(
        sed -En 's:.*filename="([^"]+)".*:\1:p' "${xml}"
    )"
    contents_filenames="$(
        sed -En 's:.*<file_name>([^<]+)</file_name>.*:\1:p' "${xml}"
    )"
    for file in $(
        echo ${rawprogram_filenames} ${contents_filenames} | sort -u
        ); do
        case "${file}" in
          # expected files that should be generated by ptool
          gpt_*|zeros_*|patch*.xml|rawprogram*.xml)
            if ! [ -r "${dir}/${file}" ]; then
                errors=yes
                echo "Missing ${file} referenced in ${xml}" >&2
            fi
          ;;
          # known files that will be provided by the OS or boot binaries
          DISK) ;;
          Quantum.fv) ;;
          XblRamdump.elf) ;;
          XblRamdump.xz) ;;
          abl.elf) ;;
          abl2esp-v7.elf) ;;
          adsp.mbn) ;;
          adsp1.mbn) ;;
          adsp1_dtbs.elf) ;;
          adsp2.mbn) ;;
          adsp2_dtbs.elf) ;;
          adsp_dtbs.elf) ;;
          adsp_lite.lzma) ;;
          aop.mbn) ;;
          aop_devcfg.mbn) ;;
          audio_cfg.mbn) ;;
          boot.img) ;;
          bootfw1.bin) ;;
          bootfw2.bin) ;;
          cdsp.mbn) ;;
          cdsp1.mbn) ;;
          cdsp1_dtbs.elf) ;;
          cdsp2.mbn) ;;
          cdsp2_dtbs.elf) ;;
          cdsp3.mbn) ;;
          cdsp3_dtbs.elf) ;;
          cdsp_dtbs.elf) ;;
          cdt.bin) ;;
          cmnlib.mbn) ;;
          cmnlib64.mbn) ;;
          cpucp.elf) ;;
          cpucp_dtbs.elf) ;;
          dcd.mbn) ;;
          ddr_lcp.elf) ;;
          devcfg.mbn) ;;
          devcfg_auto_sgvm.mbn) ;;
          devcfg_full.img) ;;
          devcfg_iot.mbn) ;;
          devcfg_rfcomm.mbn) ;;
          devcfg_windows_hyp.mbn) ;;
          display_cfg.mbn) ;;
          dtb.bin) ;;
          dtbo.img) ;;
          efi.bin) ;;
          emmc_appsboot.mbn) ;;
          featenabler.mbn) ;;
          fs_image_linux.tar.gz.mbn.img) ;;
          gearvm.mbn) ;;
          hyp.mbn) ;;
          hyp_ac_config.mbn) ;;
          hypvm.mbn) ;;
          imagefv.elf) ;;
          init_boot.img) ;;
          keymaster.mbn) ;;
          keymaster64.mbn) ;;
          keymint.mbn) ;;
          km4.mbn) ;;
          km5virt_smci.mbn) ;;
          license.bin) ;;
          logfs_ufs_8mb.bin) ;;
          machine-image-sa8797.ext4) ;;
          metadata.img) ;;
          multi_image.mbn) ;;
          multi_image_qti.mbn) ;;
          oem_misc.mbn) ;;
          onekeymint_virt.mbn) ;;
          pdp.elf) ;;
          pdp_cdb.elf) ;;
          persist.img) ;;
          pmic.elf) ;;
          prog_firehose_ddr.elf) ;;
          prog_firehose_lite.elf) ;;
          qsahara_device_programmer.xml) ;;
          qti_misc.mbn) ;;
          quantumsdk.fv) ;;
          qupv3fw.elf) ;;
          rootfs.img) ;;
          rpm.mbn) ;;
          rubikpi_config.img) ;;
          rubikpi_dtso.img) ;;
          sa8797-boot.img) ;;
