<contents>
  <product_flavors cmm_pf_var="PRODUCT_FLAVORS">
    <pf>
      <name>default</name>
      <component>
        <name>common</name>
        <flavor>default</flavor>
      </component>
      <component>
        <name>apps</name>
        <flavor>default</flavor>
      </component>
    </pf>
  </product_flavors>
  <product_info>
    <product_name>NORDIQ10.LE.0.0</product_name>
    <chipid flavor="default" storage_type="ufs" flash_phase="1">NORDIQ10</chipid>
    <additional_chipid>NORDIQ10M</additional_chipid>
    <meta_type>FULL_STACK</meta_type>
    <build_type>K2L</build_type>
  </product_info>
  <builds_flat>
    <build>
      <name>apps</name>
      <role>apps</role>
      <chipset>NORDIQ10</chipset>
      <windows_root_path>.\</windows_root_path>
      <linux_root_path>./</linux_root_path>
      <image_dir>apps_proc</image_dir>
    </build>
    <build>
      <name>common</name>
      <role>common</role>
      <chipset>NORDIQ10</chipset>
      <windows_root_path>.\</windows_root_path>
      <linux_root_path>./</linux_root_path>
      <image_dir>common</image_dir>
      <device_programmer cmm_file_var="FIREHOSE_DDR_ELF">
        <file_name>qsahara_device_programmer.xml</file_name>
        <file_path>.</file_path>
      </device_programmer>
      <download_file>
        <fastboot_complete>{partition_name}</fastboot_complete>
        <file_name>{image_name}</file_name>
        <file_path>.</file_path>
      </download_file>
      <download_file qsahara_image_id="61">
        <file_name>tme_config.elf</file_name>
        <file_path>.</file_path>
      </download_file>
      <download_file qsahara_image_id="60">
        <file_name>signed_firmware_soc_view.elf</file_name>
        <file_path>.</file_path>
      </download_file>
      <download_file qsahara_image_id="59">
        <file_name>sequencer_ram.elf</file_name>
        <file_path>.</file_path>
      </download_file>
      <download_file qsahara_image_id="21">
        <file_name>xbl_sc.elf</file_name>
        <file_path>.</file_path>
      </download_file>
      <download_file qsahara_image_id="36">
        <file_name>multi_image_qti.mbn</file_name>
        <file_path>.</file_path>
      </download_file>
      <download_file qsahara_image_id="37">
        <file_name>multi_image.mbn</file_name>
        <file_path>.</file_path>
      </download_file>
      <device_programmer cmm_file_var="DEV_PRG" qsahara_image_id="13">
        <file_name>prog_firehose_ddr.elf</file_name>
        <file_path>.</file_path>
      </device_programmer>
      <device_programmer cmm_file_var="XBL_CFG" qsahara_image_id="38">
        <file_name>xbl_config_devprg.elf</file_name>
        <file_path>.\</file_path>
      </device_programmer>
      <partition_file>
        <storage_type>{storage_type}</storage_type>
        <file_name>{partition_file_name}</file_name>
        <file_path flavor="default">.</file_path>
      </partition_file>
      <partition_patch_file>
        <storage_type>{storage_type}</storage_type>
        <file_name>{partition_patch_file_name}</file_name>
        <file_path flavor="default">.</file_path>
      </partition_patch_file>
   </build>
  </builds_flat>
</contents>
